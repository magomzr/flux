# ─── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/flux

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# Generar con:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Luego copiar el contenido en una sola línea con \n entre líneas:
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Redis (requerido para delivery multi-instancia — post-MVP) ───────────────
# REDIS_URL=redis://localhost:6379

# ─── Storage de assets (post-MVP) ────────────────────────────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
